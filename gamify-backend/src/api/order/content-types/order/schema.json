{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "orderId": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "game": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::game.game"
    },
    "eventName": {
      "type": "string"
    },
    "tickets": {
      "type": "json"
    },
    "total": {
      "type": "decimal"
    },
    "currency": {
      "type": "string",
      "default": "EUR"
    }
  }
}
